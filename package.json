{
	"name": "story-typing-final",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build && npm run build:server",
		"build:server": "vite build --config vite.server.config.ts",
		"preview": "vite preview",
		"check": "npm run build && npm run lint",
		"lint": "biome ci .",
		"lint:fix": "biome check --write .",
		"lint:staged": "biome check --staged --no-errors-on-unmatched",
		"prepare": "husky",
		"test:opening": "tsx scripts/test-opening.ts"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.104.2",
		"openai": "^6.42.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@types/node": "^25.9.3",
		"@types/react": "^19.1.0",
		"@types/react-dom": "^19.1.0",
		"@vitejs/plugin-react": "^4.3.4",
		"husky": "^9.1.7",
		"tsx": "^4.19.4",
		"typescript": "^5.6.3",
		"vite": "^5.4.11"
	}
}
